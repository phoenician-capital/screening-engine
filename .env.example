# ── Application ───────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ── Database ─────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=phoenician
DB_USER=phoenician
DB_PASSWORD=your_db_password_here

# ── Redis ────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ── LLM API Keys ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...
PERPLEXITY_API_KEY=pplx-...

# ── LLM Model Selection ─────────────────────────────────────────
# Anthropic:   claude-opus-4-6 | claude-sonnet-4-6 | claude-haiku-4-5-20251001
# OpenAI:      gpt-5.2 | gpt-5.2-pro | gpt-5-mini | gpt-5-nano | gpt-5.2-codex
#              gpt-4.1 | gpt-4.1-mini | gpt-4.1-nano
# Perplexity:  sonar-deep-research | sonar-pro | sonar-reasoning-pro
# Google:      gemini-2.5-pro | gemini-2.5-flash
PRIMARY_LLM=claude-sonnet-4-6
MEMO_LLM=claude-opus-4-6
EXTRACTION_LLM=gpt-4.1-mini
PERPLEXITY_MODEL=sonar-deep-research
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# ── Vector Store ─────────────────────────────────────────────────
VECTOR_BACKEND=pgvector
VECTOR_COLLECTION=documents
# QDRANT_HOST=localhost
# QDRANT_PORT=6333

# ── Data Sources ─────────────────────────────────────────────────
SEC_EDGAR_USER_AGENT=PhoenicianCapital admin@phoenician.capital
SEC_RATE_LIMIT_RPS=10
# NEWS_API_KEY=
# POLYGON_API_KEY=

# ── Scoring Bands ────────────────────────────────────────────────
MIN_MARKET_CAP=250000000
MAX_MARKET_CAP=5000000000
HARD_MIN_MARKET_CAP=100000000
HARD_MAX_MARKET_CAP=10000000000
